; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

metroidvania_system/settings_file="res://MetSysSettings.tres"

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Last Toast"
run/main_scene="uid://cy2ivgv628l40"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SkillsDB="*res://db/SkillsDB.gd"
MetSys="*res://addons/MetroidvaniaSystem/Nodes/Singleton.tscn"
UtilsNode="*res://Autoloads/Utils.gd"
Inventory="*res://Autoloads/Inventory.gd"
Resources="*res://Autoloads/Resources.gd"
ItemEffects="*res://Autoloads/ItemEffects.gd"
DevLoadout="*res://Autoloads/DevLoadout.gd"
LaneSystem="*res://systems/LaneSystem.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1366
window/size/window_height_override=768
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/MetroidvaniaSystem/EditorExtension/plugin.cfg", "res://addons/MetroidvaniaSystem/plugin.cfg")

